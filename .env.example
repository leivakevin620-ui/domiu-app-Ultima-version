# ============================================================================
# DOMIU — Variables de Entorno
# ============================================================================
# Copia este archivo como `.env.local` y completa los valores.
# Las variables con `NEXT_PUBLIC_` son seguras en cliente.
# Las variables SIN `NEXT_PUBLIC_` NUNCA se exponen al cliente.
# ============================================================================

# ============================================================================
# SUPABASE (OBLIGATORIO)
# ============================================================================
# Obtén estos valores en: Supabase Dashboard > Settings > API
# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vuwaqmwgvldqmmgkpyjh.supabase.co
# Anon Key (pública, segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service Role Key (SOLO servidor — NUNCA en cliente)
# Se usa para operaciones admin que necesitan bypass de RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=

# ============================================================================
# APP (OBLIGATORIO)
# ============================================================================
# URL base de la aplicación (cambiar en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# GOOGLE MAPS (OPCIONAL — Mapas habilitados)
# ============================================================================
# API Key de Google Maps Platform
# Habilita: Maps JavaScript API, Places API, Directions API, Geocoding API
# https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ============================================================================
# GOOGLE ANALYTICS (OPCIONAL)
# ============================================================================
# ID de medición de Google Analytics (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================================================
# NOTIFICACIONES PUSH (OPCIONAL — Para producción)
# ============================================================================
# VAPID Public Key para Web Push Notifications
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BBbb...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@domiu.app

# ============================================================================
# EMAIL / SMTP (OPCIONAL — Para producción)
# ============================================================================
# Configuración SMTP para emails transaccionales (Resend, SendGrid, etc.)
RESEND_API_KEY=re_...
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...
EMAIL_FROM=noreply@domiu.app

# ============================================================================
# PAGOS (OPCIONAL — Para producción)
# ============================================================================
# Wompi
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_...
WOMPI_PRIVATE_KEY=...
WOMPI_EVENT_SECRET=...
# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Mercado Pago
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-...
MP_ACCESS_TOKEN=TEST-...

# ============================================================================
# STORAGE / CLOUDINARY (OPCIONAL)
# ============================================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ============================================================================
# SEGURIDAD (OPCIONAL)
# ============================================================================
# JWT Secret para firmar tokens adicionales (no usado actualmente)
JWT_SECRET=...

# ============================================================================
# ENTORNO
# ============================================================================
NODE_ENV=development
