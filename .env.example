# DomiU / Domi AI Enterprise
# Copia este archivo como .env.local. Nunca confirmes .env.local ni secretos.

# Aplicación
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — obligatorias
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
# Clave moderna solo servidor. Debe comenzar por sb_secret_.
SUPABASE_SECRET_KEY=sb_secret_replace_me
# Compatibilidad temporal durante una rotación. Elimina esta variable al finalizar.
# SUPABASE_SERVICE_ROLE_KEY=

# Google Maps — obligatoria para mapas, ubicación y rutas
# Restringe la clave por dominio y por API en Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace_me

# Domi generativo — opcional; el motor determinista sigue operativo sin estas variables
DOMI_GENERATIVE_PROVIDER=openai
DOMI_OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=replace_me
# Sal aleatoria privada usada para anonimizar safety_identifier.
DOMI_SAFETY_SALT=replace_with_at_least_32_random_characters

# Analítica opcional
NEXT_PUBLIC_GA_ID=

# Notificaciones push opcionales
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@domiu.app

# Correo opcional
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@domiu.app

# Pagos opcionales. Domi nunca recibe ni ejecuta secretos de pago.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENT_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

# Storage opcional
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Conexión administrativa local opcional; no se necesita en Vercel runtime.
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
